# App
NEXT_PUBLIC_APP_NAME=Keywize
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# Optional Conversational AI voice/TTS settings for agent creation.
# Leave ELEVENLABS_VOICE_ID blank to use the ElevenLabs agent default voice.
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL_ID=eleven_turbo_v2
ELEVENLABS_AGENT_OUTPUT_AUDIO_FORMAT=
# Intake ID is used server-side to issue short-lived browser signed URLs.
ELEVENLABS_INTAKE_AGENT_ID=
# Caller and Closer remain server-side only. Never prefix these with NEXT_PUBLIC_.
ELEVENLABS_CALLER_AGENT_ID=
ELEVENLABS_CLOSER_AGENT_ID=

# Optional live sandbox proof. All values are server-only placeholders.
# The linked outbound phone number ID is not a destination phone number.
ELEVENLABS_SANDBOX_PHONE_NUMBER_ID=
ELEVENLABS_ENVIRONMENT=
# Team-controlled vendor persona endpoints only. Never add real locksmith numbers.
KEYWIZE_SANDBOX_VENDOR_A_PHONE=
KEYWIZE_SANDBOX_VENDOR_B_PHONE=
KEYWIZE_SANDBOX_VENDOR_C_PHONE=
# Time before an incomplete live leg visibly switches to reliable replay.
KEYWIZE_LIVE_SANDBOX_FALLBACK_MS=20000

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# Optional discovery and maps
GOOGLE_PLACES_API_KEY=

# Demo mode
NEXT_PUBLIC_DEMO_MODE=true
